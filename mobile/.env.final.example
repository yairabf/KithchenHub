# Kitchen Hub Mobile - Final environment template
# Copy to mobile/.env and fill values.

# =============================================================================
# App runtime (optional)
# =============================================================================
# Base backend URL without trailing slash
# iOS simulator: http://localhost:3000
# Android emulator: http://10.0.2.2:3000 (unless adb reverse is configured)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Privacy/terms URLs: the app calls GET /api/v1/client-links on the backend.
# Until that succeeds, links fall back to EXPO_PUBLIC_API_URL + /privacy and /terms.

# API version used for /api/v{n}
EXPO_PUBLIC_API_VERSION=1

# true/false to force mock mode
EXPO_PUBLIC_USE_MOCK_DATA=false

# =============================================================================
# Store release automation (Fastlane)
# =============================================================================
# iOS App Store Connect API key
ASC_KEY_ID=
ASC_ISSUER_ID=
# Absolute path to the downloaded .p8 key file on your machine
ASC_KEY_PATH=
# Optional convenience value for some fastlane/App Store flows
FASTLANE_APPLE_ID=

# Android Google Play service account JSON path
SUPPLY_JSON_KEY=
ANDROID_KEYSTORE_PATH=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=

# =============================================================================
# E2E-only variables (Playwright/tests)
# =============================================================================
E2E_APP_URL=http://localhost:8081
E2E_BACKEND_URL=http://localhost:3000
