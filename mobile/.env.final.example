# Kitchen Hub Mobile - Final environment template
# Copy to mobile/.env and fill values.

# =============================================================================
# App runtime (optional)
# =============================================================================
# Base backend URL without trailing slash
# iOS simulator: http://localhost:3000
# Android emulator: http://10.0.2.2:3000 (unless adb reverse is configured)
EXPO_PUBLIC_API_URL=http://localhost:3000

# API version used for /api/v{n}
EXPO_PUBLIC_API_VERSION=1

# true/false to force mock mode
EXPO_PUBLIC_USE_MOCK_DATA=false

# =============================================================================
# E2E-only variables (Playwright/tests)
# =============================================================================
E2E_APP_URL=http://localhost:8081
E2E_BACKEND_URL=http://localhost:3000
