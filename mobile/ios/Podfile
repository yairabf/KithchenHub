require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
require 'shellwords'

# xcodeproj 1.27.x passes the already-read file contents string to
# file_in_conflict? without checking for valid encoding first.  On Ruby 3.x the
# default File.read encoding is UTF-8; binary plist files inside XCFramework
# bundles contain non-UTF-8 bytes, so the conflict-marker regex match raises
# Encoding::InvalidByteSequenceError.  Monkey-patch file_in_conflict? to bail
# out early for non-UTF-8-valid strings (binary files can't have text conflict
# markers anyway).
require 'xcodeproj'
module Xcodeproj
  class Plist
    def self.file_in_conflict?(contents)
      return false unless contents.valid_encoding?
      conflict_regex = /
        ^<{7}(?!<)
        [\w\W]*
        ^={7}(?!=)
        [\w\W]*
        ^>{7}(?!>)
      /xm
      contents.match(conflict_regex)
    rescue
      false
    end
  end
end
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']
  
  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

# libwebp 1.5.0: CocoaPods strips the src/ tree from Pods/libwebp/ because the
# sharpyuv subspec only declares source_files = "sharpyuv/*.{h,c}".  The webp
# subspec declares src/**/*.{h,c} but CocoaPods' file cleanup can still remove
# files that don't match any subspec's source_files when evaluated in isolation.
#
# The sharpyuv C code #include-s files from src/ (src/webp/types.h, src/dsp/cpu.c,
# etc.), so compilation fails with "file not found" on a clean archive build.
#
# Fix: copy the full src/ tree from the CocoaPods download cache into
# Pods/libwebp/ if it's missing.  This is safe — the files are the exact same
# version (v1.5.0) that CocoaPods downloaded; we're just restoring what the
# cleanup phase incorrectly removed.
def restore_libwebp_src_tree(installer)
  pods_root = installer.sandbox.root
  libwebp_pod_dir = File.join(pods_root, 'libwebp')
  libwebp_src_dir = File.join(libwebp_pod_dir, 'src')
  return unless Dir.exist?(libwebp_pod_dir)
  return if Dir.exist?(File.join(libwebp_src_dir, 'webp'))

  cache_base = File.expand_path('~/Library/Caches/CocoaPods/Pods/Release/libwebp')
  if Dir.exist?(cache_base)
    cached_version_dir = Dir.glob(File.join(cache_base, '1.5.0*')).first
    cached_src = cached_version_dir ? File.join(cached_version_dir, 'src') : nil

    if cached_src && Dir.exist?(cached_src)
      UI.message("[libwebp] Restoring missing src/ tree from CocoaPods cache: #{cached_src}")
      FileUtils.cp_r(cached_src, libwebp_pod_dir)
      return
    end
  end

  UI.message('[libwebp] Cache miss — downloading src/ tree from GitHub')
  Dir.mktmpdir do |tmpdir|
    tarball = File.join(tmpdir, 'libwebp.tar.gz')
    system('curl', '-sL', 'https://github.com/webmproject/libwebp/archive/refs/tags/v1.5.0.tar.gz', '-o', tarball)
    system('tar', 'xzf', tarball, '-C', tmpdir)
    extracted_src = File.join(tmpdir, 'libwebp-1.5.0', 'src')
    if Dir.exist?(extracted_src)
      FileUtils.cp_r(extracted_src, libwebp_pod_dir)
    else
      UI.warn('[libwebp] Could not download src/ tree — build may fail')
    end
  end
end

# Xcode 15+ ScanDependencies and libwebp/SDWebImage explicit module failures:
# Disable CLANG_ENABLE_EXPLICIT_MODULES for pods that trip the scanner under
# the iOS 26 SDK.  Also bump the deployment target for SDWebImage which ships
# IPHONEOS_DEPLOYMENT_TARGET = 9.0 (below the Xcode 26 minimum of 12.0).
def fix_problematic_pod_build_settings(installer)
  explicit_module_pods = %w[libwebp SDWebImageWebPCoder SDWebImage]

  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      if explicit_module_pods.include?(target.name)
        config.build_settings['CLANG_ENABLE_EXPLICIT_MODULES'] = 'NO'
      end
      if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 12.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '12.0'
      end
    end
  end
end

ENV['RCT_NEW_ARCH_ENABLED'] ||= '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'KitchenHub' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    restore_libwebp_src_tree(installer)
    fix_problematic_pod_build_settings(installer)
  end
end
