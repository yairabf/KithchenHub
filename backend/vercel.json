{
  "buildCommand": "npm run vercel-build",
  "framework": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/privacy/", "destination": "/privacy.html" },
    { "source": "/", "destination": "/api/v1/health" }
  ],
  "routes": [{ "src": "/api/(.*)", "dest": "/api/[...path].ts" }],
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30
    }
  }
}

