# Kitchen Hub Backend - Final environment template
# Copy to backend/.env and fill values.

# =============================================================================
# Core runtime (required)
# =============================================================================
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/kitchen_hub?schema=public
# Optional but recommended when DATABASE_URL uses a pooler (Supabase/PgBouncer)
DIRECT_URL=postgresql://USER:PASSWORD@localhost:5432/kitchen_hub?schema=public

JWT_SECRET=change-me-to-32+chars-minimum-length-required
JWT_REFRESH_SECRET=change-me-to-32+chars-minimum-length-required
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

AUTH_BACKEND_BASE_URL=http://localhost:3000
AUTH_APP_SCHEME=kitchen-hub
AUTH_STATE_SECRET=change-me-to-32+chars-minimum-length-required
AUTH_SKIP_EMAIL_VERIFICATION=false

# Optional: full URLs for GET /api/v1/client-links (mobile/web). If unset, uses AUTH_BACKEND_BASE_URL + /privacy and /terms.
# LEGAL_PRIVACY_POLICY_URL=https://example.com/privacy
# LEGAL_TERMS_OF_SERVICE_URL=https://example.com/terms

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Needed for server-side admin operations and image uploads
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# Recipe image behavior (optional, has defaults)
# =============================================================================
RECIPE_IMAGE_SIGNED_URL_TTL_SECONDS=604800
RECIPE_IMAGE_UPLOADS_PER_HOUR=60
RECIPE_IMAGE_UPLOAD_BURST=10

# =============================================================================
# Optional OAuth
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# Optional storage provider switching
# =============================================================================
# supabase | s3 | minio
STORAGE_PROVIDER=supabase
# Default bucket used by storage adapters
STORAGE_BUCKET=household-uploads
# Legacy fallback used in storage service (keep if you rely on old path)
S3_BUCKET_NAME=household-uploads

# S3/MinIO settings (required only when STORAGE_PROVIDER=s3|minio)
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Optional public base URL override for generated public links
S3_PUBLIC_URL=http://localhost:9000

# Optional: catalog icon URL rewrite base
CATALOG_ICONS_BASE_URL=http://localhost:9000/catalog-icons

# =============================================================================
# Optional monitoring
# =============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# Optional email verification transport
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@kitchenhub.app
EMAIL_VERIFICATION_TOKEN_EXPIRY_HOURS=24

# =============================================================================
# Script/Test-only variables (not required for normal API runtime)
# =============================================================================
# Used by scripts/seed-grocery-catalog.ts
GROCERY_CATALOG_SOURCE=./output/combined_grocery_catalog.csv
# Used by src/infrastructure/database/rls.spec.ts
ALLOW_STORAGE_RLS_SKIP=false
